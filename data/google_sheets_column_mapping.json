        "wind_speed": "wind_speed",
        "wave": "wave_height",
        "payout_3t": "trifecta_payout",
        "payout_3f": "trio_payout",
        "payout_2t": "exacta_payout",
        "payout_2f": "quinella_payout",
        "note": "note"
      },
      "notes": "Each row represents one racer/boat result within a race. Race-level payout columns may be repeated across rows."
