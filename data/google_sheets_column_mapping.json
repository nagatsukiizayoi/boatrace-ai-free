    "format": "YYYYMMDD-venue_code-race_no",
    "source_columns": [
      "date",
      "jcd",
      "race"
    ],
    "normalized_columns": [
      "race_date",
      "venue_code",
      "race_no"
    ]
  },
  "output_targets": {
    "race_results_long": "data/import/history/results/results_{year}.csv",
    "race_entries_from_results": "data/import/history/race_entries/race_entries_{year}.csv"
