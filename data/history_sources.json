{
  "version": "1.0",
  "description": "History data source configuration for boatrace AI database rebuild.",
  "csv_partition": {
    "enabled": true,
    "unit": "year",
    "year_column": "race_date",
    "file_name_pattern": "{data_type}_{year}.csv"
  },
  "race_id": {
    "format": "YYYYMMDD-venue_code-race_no",
    "example": "20260101-01-01",
    "required": true
  },
  "google_sheets": [
    {
      "name": "google_sheet_1",
